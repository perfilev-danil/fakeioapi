// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id String @id @default(uuid())
  name String
  email String @unique
  password  String   
  avatar String?
  holdings Holding[]
  createdAt DateTime @default(now())
}

model Metric {
  id String @id @default(uuid())
  price Float

  coin Coin @relation(fields: [coinId], references: [id])
  coinId String

  createdAt DateTime @default(now())
}

model Coin {
  id String @id @default(uuid())
  name String
  symbol String
  apiId   String  @unique 

  metrics Metric[]
  holdings Holding[]
}

model Holding {
  id String @id @default(uuid())

  user User @relation(fields: [userId], references: [id])
  userId String

  coin Coin @relation(fields: [coinId], references: [id])
  coinId String

  amount Float

  createdAt DateTime @default(now())
}